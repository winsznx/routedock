# Stellar network — testnet (default) or mainnet
STELLAR_NETWORK=testnet

# Agent Stellar keypair — must have testnet USDC balance
# Fund via Friendbot: https://friendbot.stellar.org?addr=G...
# Then manually add USDC trustline and fund from testnet faucet
AGENT_SECRET=S...

# Optional: if using the AgentVault contract account instead of a plain keypair
# AGENT_VAULT_CONTRACT_ID=CAX5IDLC2XHGQSEA2YN3LPLZ7EXLMRXYX3HFJGKFXS6B7OQXBKWO44LT

# Local daily spend cap for policy rejection demo
# Must be > x402_price (0.001) + mpp_charge_price (0.0008) = 0.0018
# and < 0.0018 + x402_price (0.001) = 0.0028  → policy fires on step 5
AGENT_DAILY_CAP_USDC=0.002

# Provider URLs — use Railway deployed URLs or local dev servers
PROVIDER_A_URL=http://localhost:3001
PROVIDER_B_URL=http://localhost:3002

# Supabase (optional — agent only reads tx_log for verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
