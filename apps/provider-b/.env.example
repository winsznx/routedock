# Stellar network — testnet (default) or mainnet
STELLAR_NETWORK=testnet

# Server/payee Stellar keypair
STELLAR_PAYEE_SECRET=S...
STELLAR_PAYEE_ADDRESS=G...

# One-way-channel Soroban contract address (C...)
# Deployed from stellar-experimental/one-way-channel
CHANNEL_CONTRACT_ID=C...

# Testnet USDC Stellar Asset Contract address
USDC_ASSET_CONTRACT=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Supabase — server-side service key (never expose to clients)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Server port — Railway assigns $PORT automatically
PORT=3002
