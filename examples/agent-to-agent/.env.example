# Copy this file to .env and fill in funded Stellar testnet secrets.
#
# ORCHESTRATOR_SECRET is the orchestrator agent's Stellar keypair.
ORCHESTRATOR_SECRET=S...

# SPECIALIST_SECRET is the specialist sub-agent's Stellar keypair.
# In a real deployment this is a separate funded account.
SPECIALIST_SECRET=S...

# Whether to start the mock specialist server in-process.
START_MOCK_SPECIALIST=true

# RouteDock network for both agents.
STELLAR_NETWORK=testnet
