# Copy this file to .env and fill in funded Stellar testnet secrets.
#
# Create a keypair, fund it with Friendbot, then paste the secret key here.
AGENT_SECRET=S...

# The mock inference provider runs locally on port 3100.
# Point this at a live RouteDock-compatible inference endpoint for mainnet.
INFERENCE_PROVIDER_URL=http://localhost:3100

# Whether to start the mock provider in-process. Set to "false" when pointing
# at an external provider.
START_MOCK_PROVIDER=true

# RouteDock network for both provider and client.
STELLAR_NETWORK=testnet
