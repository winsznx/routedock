# Copy this file to .env and fill in funded Stellar testnet secrets.
#
# Create a keypair, fund it with Friendbot, then paste the secret key here.
AGENT_SECRET=S...

# Provider A exposes GET /price over x402.
# Defaults to the public testnet deployment.
PROVIDER_A_URL=https://api-a.routedock.xyz

# RouteDock provider-a is deployed on Stellar testnet.
STELLAR_NETWORK=testnet
