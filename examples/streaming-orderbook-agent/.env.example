# Copy this file to .env and fill in funded Stellar testnet secrets.
#
# Create a keypair locally, fund the public key with Friendbot, and use the
# secret key here. The account must exist on Stellar testnet so settlement can
# prepare and close the MPP channel.
AGENT_SECRET=S...

# MPP uses an ed25519 keypair for off-chain cumulative vouchers. Provider B
# must be configured with this keypair's public key as COMMITMENT_PUBLIC_KEY.
# For local testnet demos you may reuse AGENT_SECRET; production agents should
# use a separate commitment key with tighter operational controls.
COMMITMENT_SECRET=S...

# Provider B exposes the RouteDock manifest plus /stream/orderbook.
PROVIDER_B_URL=https://api-b.routedock.xyz

# RouteDock provider-b is configured for Stellar testnet.
STELLAR_NETWORK=testnet
