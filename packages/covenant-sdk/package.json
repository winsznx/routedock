{
  "name": "@routedock/covenant-sdk",
  "version": "0.1.0",
  "description": "Off-chain ZK proof builder for Covenant smart accounts on Stellar",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/covenant.test.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5"
  }
}
