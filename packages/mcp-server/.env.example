# Required: Stellar secret key for the wallet that will make payments
STELLAR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: Stellar network (testnet or mainnet)
STELLAR_NETWORK=testnet

# Optional: Ed25519 secret key for signing channel commitments (required for mpp-session mode)
COMMITMENT_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Supabase credentials for provider registry access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
