{
  "name": "@routedock/routedock",
  "version": "0.1.2",
  "description": "Unified payment execution layer for autonomous agents on Stellar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/winsznx/routedock.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ],
      "provider": [
        "dist/provider.d.ts"
      ],
      "react": [
        "dist/react.d.ts"
      ],
      "testing": [
        "dist/testing.d.ts"
      ],
      "provider/hono": [
        "dist/provider/hono.d.ts"
      ],
      "provider/fastify": [
        "dist/provider/fastify.d.ts"
      ],
      "schema": [
        "dist/schema.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/provider.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./provider/hono": {
      "types": "./dist/provider/hono.d.ts",
      "import": "./dist/provider/hono.js",
      "require": "./dist/provider/hono.cjs"
    },
    "./provider/fastify": {
      "types": "./dist/provider/fastify.d.ts",
      "import": "./dist/provider/fastify.js",
      "require": "./dist/provider/fastify.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --experimental-test-module-mocks --test src/__tests__/retry.test.ts src/__tests__/manifest-sign.test.ts src/internal/__tests__/usdc.test.ts src/client/__tests__/dispute.test.ts src/client/__tests__/session-timeout.test.ts src/client/__tests__/manifest-timeout.test.ts src/tests/smoke.test.ts src/provider/__tests__/hono.test.ts src/provider/__tests__/encoding.test.ts src/provider/__tests__/SeenTxStore.test.ts src/react/__tests__/useRouteDockClient.test.tsx src/react/__tests__/usePay.test.tsx src/react/__tests__/useSession.test.tsx src/react/__tests__/useTxLog.test.tsx"
  },
  "dependencies": {
    "@routedock/covenant-sdk": "workspace:*",
    "@stellar/mpp": "^0.4.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@supabase/supabase-js": "^2.47.0",
    "@x402/core": "^2.9.0",
    "@x402/stellar": "^2.9.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "mppx": "^0.5.7"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "hono": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "fastify": "^5.0.0",
    "hono": "^4.12.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "viem": "^2.52.0"
  }
}
