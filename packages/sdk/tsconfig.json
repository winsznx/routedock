{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"]
}
